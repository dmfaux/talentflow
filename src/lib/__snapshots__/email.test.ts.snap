exports[`email templates — branded theme render > applicationReceivedEmail carries brand palette + logo, no powered-by 1`] = `
"<!DOCTYPE html PUBLIC "-//W3C//DTD XHTML 1.0 Transitional//EN" "http://www.w3.org/TR/xhtml1/DTD/xhtml1-transitional.dtd">
<html lang="en" xmlns="http://www.w3.org/1999/xhtml">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <meta name="color-scheme" content="light">
  <meta name="supported-color-schemes" content="light">
  <title>TalentStream</title>
  <!--[if mso]>
  <style type="text/css">
    table, td, div, h1, p { font-family: Georgia, 'Times New Roman', serif; }
  </style>
  <![endif]-->
  <style type="text/css">
    
    body, table, td, a { -webkit-text-size-adjust:100%; -ms-text-size-adjust:100%; }
    table, td { mso-table-lspace:0pt; mso-table-rspace:0pt; }
    img { -ms-interpolation-mode:bicubic; border:0; outline:none; text-decoration:none; }
    a { color:#006341; }
    @media (max-width: 620px) {
      .ts-card { width:100% !important; max-width:100% !important; }
      .ts-pad { padding-left:28px !important; padding-right:28px !important; }
      .ts-headline { font-size:26px !important; }
    }
  </style>
</head>
<body style="margin:0;padding:0;background-color:#0b1f14;-webkit-font-smoothing:antialiased;-moz-osx-font-smoothing:grayscale;">
  <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color:#0b1f14;">
    <tr><td align="center" style="padding:56px 16px;">

      <table role="presentation" class="ts-card" width="580" cellpadding="0" cellspacing="0" border="0" style="max-width:580px;width:100%;">

        <!-- Top accent bar — cobalt -->
        <tr><td style="height:3px;background-color:#006341;border-radius:6px 6px 0 0;font-size:0;line-height:0;mso-line-height-rule:exactly;">&nbsp;</td></tr>

        <!-- Card -->
        <tr><td style="background:#0f2a1c;border-left:1px solid #1d4533;border-right:1px solid #1d4533;border-bottom:1px solid #1d4533;border-radius:0 0 6px 6px;">

          <!-- Brand header -->
          <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
            <tr><td class="ts-pad" style="padding:26px 44px 24px;border-bottom:1px solid #1d4533;">
              
    <table role="presentation" cellpadding="0" cellspacing="0" border="0" align="center" style="border-collapse:separate;">
      <tr><td style="padding:10px 14px;background-color:#f2f7f4;border-radius:6px;">
        <img src="https://cdn.example.com/acme-logo.png" alt="Logo" style="display:block;max-height:44px;width:auto;border:0;outline:none;text-decoration:none;">
      </td></tr>
    </table>
            </td></tr>
          </table>

          <!-- Body -->
          <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
            <tr><td class="ts-pad" style="padding:40px 44px 44px;">
              
    
    <p style="margin:0 0 10px;font-family:Arial, Helvetica, sans-serif;font-size:11px;text-transform:uppercase;letter-spacing:0.16em;color:#006341;font-weight:600;">
      <span style="display:inline-block;width:18px;height:1px;background-color:#b4c905;vertical-align:middle;margin-right:10px;"></span>Confirmation
    </p>
    <h1 class="ts-headline" style="margin:0 0 24px;font-family:Georgia, 'Times New Roman', serif;font-size:30px;color:#f2f7f4;font-weight:400;line-height:1.12;letter-spacing:-0.015em;">We&rsquo;ve got your application</h1>
    <p style="margin:0 0 16px;font-family:Arial, Helvetica, sans-serif;font-size:15px;color:#d6e4dc;line-height:1.7;">Hi Thabo Mokoena,</p>
    <p style="margin:0 0 16px;font-family:Arial, Helvetica, sans-serif;font-size:15px;color:#d6e4dc;line-height:1.7;">Thank you for applying. We&rsquo;ve received your application and it&rsquo;s now being reviewed.</p>
    
    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="margin:22px 0 6px;">
      <tr>
        <td width="3" style="background-color:#006341;border-radius:2px 0 0 2px;font-size:0;line-height:0;">&nbsp;</td>
        <td style="padding:18px 22px;background-color:#103a28;border-radius:0 4px 4px 0;">
          
    <p style="margin:0 0 3px;font-family:Arial, Helvetica, sans-serif;font-size:10px;text-transform:uppercase;letter-spacing:0.14em;color:#9fb5a8;font-weight:600;">Role</p>
    <p style="margin:0 0 14px;font-family:Georgia, 'Times New Roman', serif;font-size:18px;color:#f2f7f4;line-height:1.3;">Senior Backend Engineer</p>
    <p style="margin:0 0 3px;font-family:Arial, Helvetica, sans-serif;font-size:10px;text-transform:uppercase;letter-spacing:0.14em;color:#9fb5a8;font-weight:600;">Company</p>
    <p style="margin:0;font-family:Georgia, 'Times New Roman', serif;font-size:18px;color:#f2f7f4;line-height:1.3;">Açme & Co <Pty> Ltd</p>
        </td>
      </tr>
    </table>
    <p style="margin:20px 0 0;padding-top:18px;border-top:1px solid #1d4533;font-family:Arial, Helvetica, sans-serif;font-size:13px;color:#9fb5a8;line-height:1.65;">You&rsquo;ll hear from us soon with an update on next steps.</p>
  
            </td></tr>
          </table>

        </td></tr>
      </table>

      <!-- Footer -->
      <table role="presentation" width="580" cellpadding="0" cellspacing="0" border="0" style="max-width:580px;width:100%;">
        <tr><td style="padding:22px 44px;text-align:center;">
          <p style="margin:0;font-family:Arial, Helvetica, sans-serif;font-size:11px;color:#6f8678;line-height:1.55;letter-spacing:0.02em;">
            Automated message — please do not reply
          </p>
        </td></tr>
      </table>

    </td></tr>
  </table>
</body>
</html>"
`;

