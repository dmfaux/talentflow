            <tr>
              <td height="3" width="7" style="background-color:#2c5bff;opacity:0.4;border-radius:2px;font-size:0;line-height:3px;mso-line-height-rule:exactly;">&nbsp;</td>
              <td valign="middle" style="padding-left:3px;font-size:0;line-height:0;">
                <span style="display:inline-block;width:5px;height:5px;border-radius:50%;background-color:#05dbd6;"></span>
              </td>
            </tr>
          </table>
        </td>
        <!-- Wordmark -->
        <td valign="middle">
          <span style="font-family:'Instrument Sans', -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Helvetica Neue', Helvetica, Arial, sans-serif;font-size:19px;font-weight:700;letter-spacing:-0.03em;color:#11123c;line-height:1;">
            talent<span style="color:#2c5bff;">stream</span>
          </span>
        </td>
      </tr>
    </table>
            </td></tr>
          </table>

          <!-- Body -->
