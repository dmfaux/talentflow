        <!-- Top accent bar — cobalt -->
        <tr><td style="height:3px;background-color:#2c5bff;border-radius:6px 6px 0 0;font-size:0;line-height:0;mso-line-height-rule:exactly;">&nbsp;</td></tr>

        <!-- Card -->
        <tr><td style="background:#ffffff;border-left:1px solid #d1dce6;border-right:1px solid #d1dce6;border-bottom:1px solid #d1dce6;border-radius:0 0 6px 6px;">

          <!-- Brand header -->
          <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
            <tr><td class="ts-pad" style="padding:26px 44px 24px;border-bottom:1px solid #d1dce6;">
              
    <table role="presentation" cellpadding="0" cellspacing="0" border="0" style="border-collapse:separate;">
      <tr>
        <!-- Mark: 4 descending cobalt bars = candidate funnel -->
        <td valign="middle" style="padding-right:12px;">
          <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="26" style="border-collapse:separate;">
            <tr><td height="3" width="26" style="background-color:#2c5bff;opacity:1;border-radius:2px;font-size:0;line-height:3px;mso-line-height-rule:exactly;">&nbsp;</td><td style="font-size:0;line-height:0;">&nbsp;</td></tr>
    <tr><td height="3" colspan="2" style="font-size:0;line-height:3px;mso-line-height-rule:exactly;">&nbsp;</td></tr>
            <tr><td height="3" width="20" style="background-color:#2c5bff;opacity:0.78;border-radius:2px;font-size:0;line-height:3px;mso-line-height-rule:exactly;">&nbsp;</td><td style="font-size:0;line-height:0;">&nbsp;</td></tr>
    <tr><td height="3" colspan="2" style="font-size:0;line-height:3px;mso-line-height-rule:exactly;">&nbsp;</td></tr>
            <tr><td height="3" width="13" style="background-color:#2c5bff;opacity:0.58;border-radius:2px;font-size:0;line-height:3px;mso-line-height-rule:exactly;">&nbsp;</td><td style="font-size:0;line-height:0;">&nbsp;</td></tr>
