{
  "name": "interview-insider",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:seed": "tsx src/db/seed.ts",
    "db:seed:admin": "tsx src/db/seed-admin.ts",
    "db:studio": "drizzle-kit studio",
    "storage:init": "tsx scripts/init-storage.ts",
    "storage:backfill": "tsx scripts/backfill-blob-paths.ts",
    "jobs:poll": "while true; do curl -s -X POST http://localhost:3000/api/jobs/process; echo '\r'; sleep 10; done"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.68",
    "@ai-sdk/openai": "^3.0.52",
    "@ai-sdk/openai-compatible": "^2.0.41",
    "@ai-sdk/react": "^3.0.155",
    "@azure/service-bus": "^7.9.0",
    "@azure/storage-blob": "^12.31.0",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/noto-serif": "^5.2.9",
    "ai": "^6.0.153",
    "bcryptjs": "^3.0.2",
    "dotenv": "^17.4.0",
    "drizzle-orm": "^0.45.2",
    "jose": "^6.2.2",
    "jszip": "^3.10.1",
    "mammoth": "^1.12.0",
    "marked": "^18.0.0",
    "next": "16.2.2",
    "nodemailer": "^8.0.4",
    "pdf-parse": "^2.4.5",
    "postgres": "^3.4.8",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "^6.10.0",
    "satori": "^0.26.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.0",
    "@types/pdf-parse": "^1.1.5",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.9"
  }
}
