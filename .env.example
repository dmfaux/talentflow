DATABASE_URL=postgresql://user:password@localhost:5432/interview_insider
# Local dev: use the Azurite well-known connection string (see docker-compose.yml)
# AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=http;AccountName=devstoreaccount1;AccountKey=Eby8vdM02xNOcqFlqUwJPLlmEtlCDXJ1OUzFT50uSRZ6IFsuFq2UVErCz4I6tq/K1SZFPTOtr/KBHBeksoGMGw==;BlobEndpoint=http://127.0.0.1:10000/devstoreaccount1;
AZURE_STORAGE_CONNECTION_STRING=
# Private container for CVs/PII (SAS-only reads)
AZURE_STORAGE_CONTAINER_NAME=
# Public container for branding logos — S6 keeps logos directly embeddable while
# the CV container above is private. Run `npm run storage:init` to provision both.
AZURE_STORAGE_LOGO_CONTAINER_NAME=
# AI provider chain: comma-separated, tried in order on failure
# Options: anthropic, openai, openrouter, local
AI_PROVIDERS=anthropic
# Model per provider (defaults shown)
AI_ANTHROPIC_MODEL=claude-sonnet-4-6
AI_OPENAI_MODEL=gpt-4o
AI_OPENROUTER_MODEL=anthropic/claude-sonnet-4-6
AI_LOCAL_MODEL=default
AI_LOCAL_BASE_URL=http://localhost:11434/v1
AI_LOCAL_API_KEY=
# Anthropic
ANTHROPIC_API_KEY=
# OpenAI (when "openai" is in AI_PROVIDERS)
OPENAI_API_KEY=
# OpenRouter (when "openrouter" is in AI_PROVIDERS)
OPENROUTER_API_KEY=
OPENROUTER_SITE_URL=
OPENROUTER_SITE_NAME=Interview Insider
# Email provider: "smtp" for local dev (default), "resend" for production
EMAIL_PROVIDER=smtp
RESEND_API_KEY=
# SMTP settings (local dev only — used by Mailpit)
SMTP_HOST=localhost
SMTP_PORT=1026
WATI_API_URL=https://live-mt-server.wati.io
WATI_API_KEY=
WATI_WEBHOOK_SECRET=
# Apex domain (S12 host routing). The authenticated app + operator console are
# served at app.{NEXT_PUBLIC_APP_DOMAIN}; each brand's public careers site at
# {brandSlug}.{NEXT_PUBLIC_APP_DOMAIN}; the apex and www are the marketing
# landing. Reserved subdomains (see RESERVED_SLUGS in src/lib/slug.ts —
# www/api/app/admin/…) never resolve to a brand. Needs wildcard DNS + a
# *.{NEXT_PUBLIC_APP_DOMAIN} TLS cert + an app. record (infra).
NEXT_PUBLIC_APP_DOMAIN=talentstream.co.za
# Absolute origin used to build candidate-facing /c/* links (chat magic links,
# worker chat invitations/nudges). Must name a host that serves /c/* — the app
# host (https://app.{NEXT_PUBLIC_APP_DOMAIN}). Falls back to the request origin /
# http://localhost:3000 when unset, so local dev needs nothing here.
NEXT_PUBLIC_APP_URL=
ADMIN_AUTH_SECRET=
EMAIL_FROM=
# Where homepage "request access" enquiries (POST /api/contact) are emailed.
# Falls back to hello@talentstream.co.za when unset.
CONTACT_NOTIFY_EMAIL=
# Used by `npm run db:seed:admin` to bootstrap the first owner (tenant admin)
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
SEED_ADMIN_FIRST_NAME=
SEED_ADMIN_LAST_NAME=
SEED_ADMIN_CLIENT_SLUG=
# Optional: org the seed brand belongs to. Defaults to "demo-org" so a DB that
# already ran the 0026 backfill reuses that org instead of creating a second one.
SEED_ADMIN_ORG_SLUG=
# Tenant-less operator (cross-tenant) account — required, distinct email +
# password from the owner above.
SEED_OPERATOR_EMAIL=
SEED_OPERATOR_PASSWORD=
SEED_OPERATOR_FIRST_NAME=
SEED_OPERATOR_LAST_NAME=
# Queue provider: "db" for local dev (default), "servicebus" for production
QUEUE_PROVIDER=db
# Azure Service Bus (production only)
AZURE_SERVICE_BUS_CONNECTION_STRING=
# Worker endpoint protection (optional in dev). Also gates the monthly billing
# tick at POST /api/jobs/billing-close (call it from an external cron, e.g.
# `0 2 1 * *`, with header `x-worker-secret: $WORKER_SECRET`).
WORKER_SECRET=
# Usage-based pricing — South African tax-invoice fields rendered on invoice
# emails (usage-based pricing, Phase 6). VAT registration number shown on the
# tax invoice; EFT banking details candidates pay into (free text, one block).
BILLING_VAT_NUMBER=
BILLING_BANK_DETAILS=
